{
  "name": "@ucp/core",
  "version": "0.1.0",
  "description": "Universal Context Package (UCP) — reference library: validation, TypeScript types, canonical LLM rendering",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "sync-schema": "node tools/sync-schema.mjs"
  },
  "keywords": ["ucp", "llm", "context", "context-engineering", "mcp"],
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
